.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# Kiro 설정 (로컬 전용)
.kiro/

# AWS 관련
.aws-sam/
samconfig.toml
packaged-template.yaml
packaged-template.yml

# CloudFormation 빌드 아티팩트
*.packaged.yaml
*.packaged.yml
cdk.out/
cdk.out.*/

# 임시 파일
*.tmp
*.bak
