# AWS credentials (server-side only, used by API routes)
# On EC2 with an IAM role, leave these commented out to use the instance profile.
# Only set explicit keys when running off-EC2 (e.g. local laptop).
# AWS_ACCESS_KEY_ID=your-access-key-id
# AWS_SECRET_ACCESS_KEY=your-secret-access-key

# Dashboard-specific region override (avoids conflict with system AWS_REGION)
DASHBOARD_AWS_REGION=us-west-2

# Resource tag filter for EC2/Batch instance discovery
AWS_RESOURCE_TAG_KEY=Project
AWS_RESOURCE_TAG_VALUE=IsaacLab-RL

# Set to "true" to use mock data instead of live AWS calls (default for local dev)
USE_MOCK_DATA=true
