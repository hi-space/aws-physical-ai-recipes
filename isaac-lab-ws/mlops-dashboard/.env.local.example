# AWS credentials (server-side only, used by API routes)
AWS_REGION=us-west-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Tag filter: only fetch EC2/Batch resources matching this tag
AWS_RESOURCE_TAG_KEY=Project
AWS_RESOURCE_TAG_VALUE=IsaacLab-RL

# Set to "true" to use mock data instead of real AWS calls (for local dev)
USE_MOCK_DATA=true
